#!/usr/bin/env bash
#
# Build

set -e -o pipefail

: "${PREFIX:=/usr/local}"
: "${LIBDIR:="${PREFIX}/lib"}"
: "${BINDIR:="${PREFIX}/bin"}"

usage() {
  echo "Usage: $(basename "$0") <command> [options]" >&2
  echo "" >&2
  echo "Available commands:" >&2
  echo "  check      Run style and static analysis checks" >&2
  echo "  test       Run the bats test suite" >&2
  echo "  image      Build the development container image" >&2
  echo "  install    Install bats-mock to the system" >&2
  exit 1
}

command_check() {
  local do_style_check=true
  local do_static_analysis=true
  local skip_link_check=false
  local status=0

  # Parse options
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --style-only) do_static_analysis=false ;;
    --analyis-only) do_style_check=false ;;
    --skip-link) skip_link_check=true ;;
    -*)
      echo "Unknown option: $1" >&2
      return 2
      ;;
    *) break ;;
    esac
    shift
  done

  if "${do_style_check}"; then
    run_check_tool shfmt --diff . || status=$?
    # For now don't fail the check if rumdl is not installed or the
    # documentation is not perfect.
    run_check_tool rumdl check . || true
  fi

  if "${do_static_analysis}"; then
    run_check_tool shellcheck src/*.bash test/*.bats || status=$?
  fi

  if "${skip_link_check}"; then
    echo "Skip checking links in documentation."
  else
    run_check_tool lychee --cache . || status=$?
  fi

  return "$status"
}

run_check_tool() {
  local tool="$1"
  shift

  # ANSI colors (fall back to plain if not a terminal)
  local green="" red="" reset=""
  if [[ -t 1 ]]; then
    green='\033[0;32m'
    red='\033[0;31m'
    reset='\033[0m'
  fi

  echo "Running ${tool}..."
  if ! command -v "$tool" >/dev/null 2>&1; then
    echo -e "${red}❌ ${tool} is not installed.${reset}"
    return 2
  elif ! ${tool} "$@"; then
    echo -e "${red}❌ ${tool} check failed.${reset}"
    return 1
  else
    echo -e "${green}✅ ${tool} check passed.${reset}"
  fi
}

command_install() {
  if [[ "${LIBDIR:0:1}" != '/' ]]; then
    echo "$(basename "$0"): LIBDIR must be an absolute path" >&2
    exit 1
  fi

  BATS_MOCK_ROOT="${0%/*}"
  BATS_LIBDIR=${LIBDIR}/bats-mock
  install -d -m 755 "${BATS_LIBDIR}/src"
  install -v -m 755 "${BATS_MOCK_ROOT}/load.bash" "${BATS_LIBDIR}"
  install -v -m 755 "${BATS_MOCK_ROOT}/src/"* "${BATS_LIBDIR}/src"
}

command_test() {
  if [[ "${BINDIR:0:1}" != '/' ]]; then
    echo "$(basename "$0"): BINDIR must be an absolute path" >&2
    exit 1
  fi
  PATH="${PATH}:${BINDIR}"
  if [[ $# -eq 0 ]]; then
    # Run all tests if no arguments are provided
    bats test
  else
    bats "$@"
  fi
}

container_cli() {
  if command -v podman >/dev/null 2>&1; then
    echo podman
  elif command -v docker >/dev/null 2>&1; then
    echo docker
  else
    echo "❌ Neither podman nor docker is installed." >&2
    exit 1
  fi
}

command_image() {
  local image_name

  image_name="$(resolve_container_image_name "$@")"
  build_container_image "${image_name}" || return 1
  echo "export BATS_MOCK_DEV_CONTAINER=${image_name}"
}

resolve_container_image_name() {
  if [[ $# -gt 0 ]]; then
    echo "$1"
  elif [[ -n "${BATS_MOCK_DEV_CONTAINER:-}" ]]; then
    echo "${BATS_MOCK_DEV_CONTAINER}"
  else
    echo "Usage: $(basename "$0") image [IMAGE_NAME]" >&2
    echo "Set BATS_MOCK_DEV_CONTAINER or provide IMAGE_NAME." >&2
    exit 1
  fi
}

build_container_image() {
  local image_name="$1"
  local container_runtime

  container_runtime="$(container_cli)"

  echo "Building container image '${image_name}'"
  "${container_runtime}" build -t "${image_name}" -f ./.devcontainer/Containerfile .
}

run_in_container() {
  local container_runtime

  echo "Using dev container: ${BATS_MOCK_DEV_CONTAINER}"
  container_runtime="$(container_cli)"

  if ! "${container_runtime}" image inspect "${BATS_MOCK_DEV_CONTAINER}" >/dev/null 2>&1; then
    build_container_image "${BATS_MOCK_DEV_CONTAINER}"
  fi

  "${container_runtime}" run -it --rm \
    -v "$PWD":/code \
    -w /code \
    --entrypoint /bin/bash \
    "$BATS_MOCK_DEV_CONTAINER" \
    ./build "$@"
}

main() {
  local command_name="${1:-}"

  # If BATS_MOCK_CONTAINER is set → run inside container
  if [[ -n "${BATS_MOCK_DEV_CONTAINER:-}" && "${command_name}" != 'image' ]]; then
    run_in_container "$@"
    return
  fi

  # Normal non-container execution
  if [[ "${PREFIX:0:1}" != '/' ]]; then
    echo "$(basename "$0"): PREFIX must be an absolute path" >&2
    exit 1
  fi

  if [[ -z "${command_name}" ]]; then
    usage
  fi

  "command_${command_name}" "${@:2}"
}

main "$@"
